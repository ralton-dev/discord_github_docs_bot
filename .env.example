# Copy this file to `.env` and fill in the blanks.
# `.env` is gitignored; `.env.example` is the canonical list of vars the
# local stack reads. Env-var names match deploy/helm/gitdoc (ConfigMap + Secret)
# so local dev and prod stay in sync.

# ---------------------------------------------------------------------------
# Postgres
# ---------------------------------------------------------------------------
# Same variable name as the Helm secret (see deploy/helm/gitdoc/templates/secret.yaml).
# The default points at the compose `db` service; override if you run Postgres
# elsewhere.
POSTGRES_DSN=postgresql://gitdoc:gitdoc@db:5432/gitdoc

# ---------------------------------------------------------------------------
# LiteLLM (OpenAI-compatible) — rag + ingestion use this
# ---------------------------------------------------------------------------
# Two common modes for local dev (see comment block in docker-compose.yml):
#   (a) SSH tunnel to the homelab LiteLLM:   http://host.docker.internal:4000
#   (b) Your own mock on the host:           http://host.docker.internal:<port>
# We do not bundle a mock.
LITELLM_BASE_URL=http://host.docker.internal:4000
LITELLM_API_KEY=sk-replace-me

# Must match a model alias exposed by your LiteLLM instance.
EMBED_MODEL=text-embedding-3-small
CHAT_MODEL=claude-opus-4-7

# ---------------------------------------------------------------------------
# Ingestion (one-shot `docker compose run --rm ingest`)
# ---------------------------------------------------------------------------
# "self" is the convention for "this repo" in local dev — REPO_NAME=self lets
# `/ask` queries with repo:"self" match the freshly-ingested chunks.
# Replace <your-user> with your GitHub username (or any accessible URL).
REPO_URL=https://github.com/<your-user>/discord_github_chatbot.git
REPO_NAME=self
REPO_BRANCH=main

# Optional; only needed for private repos. Uses x-access-token auth.
GIT_TOKEN=

# Embedding batch size (matches deploy/helm/gitdoc/values.yaml `ingestion.embedBatch`).
EMBED_BATCH=64

# ---------------------------------------------------------------------------
# Discord bot (opt-in via `docker compose --profile bot up bot`)
# ---------------------------------------------------------------------------
# Get a token from https://discord.com/developers/applications. The bot needs
# `applications.commands` scope when invited to a guild. No privileged gateway
# intents are required (bot.py uses `Intents.default()`).
DISCORD_BOT_TOKEN=

# Where the bot reaches the orchestrator. Inside compose, this is the service
# name; on host it'd be http://localhost:8000.
RAG_ORCHESTRATOR_URL=http://rag:8000

# Which repo slug the bot's /ask command queries. Keep in sync with REPO_NAME.
TARGET_REPO=self

# Comma-separated guild IDs allowed to use /ask. Empty = allow all.
GUILD_ALLOWLIST=

# ---------------------------------------------------------------------------
# Logging (all services)
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO
