# gitdoc per-instance values template.
#
# 1. Copy this file to values-<slug>.yaml in the same directory.
#       cp values-instance.yaml.template values-<slug>.yaml
# 2. Replace every CHANGE_ME / <...> placeholder below.
# 3. Run from the repo root:
#       make helm-install REPO=<slug>
#
# Secrets — pick ONE path (see deploy/SECRETS.md for the full procedure):
#
#   A. SEALED (default, recommended).
#      - Produce a SealedSecret via `kubeseal` and commit it to
#        `deploy/sealed-secrets/<slug>.yaml`.
#      - Set `secrets.existingSecret: gitdoc-<slug>` below (the name must
#        match the Secret's `metadata.name` in your sealed manifest).
#      - Leave the inline `secrets.*` fields commented out — they are
#        ignored when `existingSecret` is set.
#
#   B. BOOTSTRAP (first deploy, before sealed-secrets is installed).
#      - Leave `secrets.existingSecret` empty.
#      - Uncomment the plaintext fields and fill them in.
#      - WARNING: this file then contains plaintext credentials; the repo's
#        .gitignore already excludes `values-*.yaml` (except the example).
#        Do not `git add -f` it. Migrate to path A as soon as sealed-
#        secrets is installed on the cluster.
#
# Naming rules
# ------------
# - <slug> matches the Postgres role/db produced by db/provision/provision-
#   instance.sql (lowercase letters, digits, underscores). The Helm release
#   name becomes `gitdoc-<slug>` and lives in namespace `gitdoc-<slug>`.
# - The slug used in `repo.name` below is also what the chunks table is
#   keyed on (repo column) and what the RAG orchestrator's /ask payload
#   sends. Pick it once; changing it later means re-ingesting.

# ---------------------------------------------------------------------------
# Repository being indexed
# ---------------------------------------------------------------------------
repo:
  # Slug — must match the namespace suffix and the Postgres slug. Use
  # hyphens or underscores; whichever you pick, be consistent.
  name: "CHANGE_ME_slug"
  # Public HTTPS clone URL. For private repos add `secrets.gitToken` below.
  url:  "https://github.com/CHANGE_ME_org/CHANGE_ME_repo.git"
  # Branch to track. Most projects: main. Some still use master.
  branch: "main"

# ---------------------------------------------------------------------------
# Image tags — pin to the resolved tag from `make print-tag` at deploy time.
# That command emits e.g. 0.1.0-9b83072. Pin every service to the SAME tag
# unless you are intentionally rolling out a partial upgrade.
# ---------------------------------------------------------------------------
images:
  bot:        { tag: "CHANGE_ME_release_tag" }   # e.g. 0.1.0-9b83072
  rag:        { tag: "CHANGE_ME_release_tag" }
  ingestion:  { tag: "CHANGE_ME_release_tag" }

# ---------------------------------------------------------------------------
# Secrets — default path is sealed-secrets. See deploy/SECRETS.md.
# ---------------------------------------------------------------------------
secrets:
  # PATH A — SEALED (default). Set this to the name of the Secret that the
  # sealed-secrets controller materialises in the release namespace. The
  # committed manifest lives at deploy/sealed-secrets/<slug>.yaml.
  existingSecret: "gitdoc-CHANGE_ME_slug"

  # PATH B — BOOTSTRAP (plaintext). Uncomment and fill in for the very
  # first deploy BEFORE sealed-secrets is installed. If you use this path,
  # leave `existingSecret` empty above. These fields are ignored when
  # `existingSecret` is set. Migrate to Path A as soon as possible.
  #
  # Discord bot token from https://discord.com/developers/applications/<id>/bot
  # discordBotToken: "CHANGE_ME_discord_bot_token"
  #
  # LiteLLM API key (the `master_key` or a virtual key on the LiteLLM proxy).
  # litellmApiKey: "CHANGE_ME_litellm_key"
  #
  # Postgres DSN built from db/provision/README.md step 3:
  #   postgresql://gitdoc_<slug>:<password>@<host>:5432/gitdoc_<slug>?sslmode=require
  # postgresDsn: "postgresql://gitdoc_CHANGE_ME_slug:CHANGE_ME_password@CHANGE_ME_pg_host:5432/gitdoc_CHANGE_ME_slug?sslmode=require"
  #
  # Personal access token for private repo clones. Leave "" for public repos.
  # GitHub: a fine-grained PAT scoped to read-only on the single repo is enough.
  # gitToken: ""
  #
  # Shared secret for /webhook signature verification. Only required when
  # `webhook.enabled` is true (see docs/webhooks.md for the GitHub/GitLab setup).
  # webhookSecret: "CHANGE_ME_webhook_secret"

# ---------------------------------------------------------------------------
# Retrieval (optional, see docs/retrieval.md). Hybrid search (BM25 + vector
# fused via RRF) is on by default; disable per-instance only if you need to
# isolate a backend issue or A/B against vector-only.
# ---------------------------------------------------------------------------
# search:
#   hybrid:
#     enabled: false

# ---------------------------------------------------------------------------
# Cross-encoder reranker (optional, see docs/retrieval.md "Reranker"). When
# enabled, /ask fetches top_k * candidatesMultiplier candidates from
# retrieval and reorders them via a cross-encoder before LLM context
# building. Off by default — turn on once a reranker endpoint is reachable
# from the cluster (typically the homelab Ollama with bge-reranker-v2-m3,
# or a small adapter exposing LiteLLM's /v1/rerank shape).
# ---------------------------------------------------------------------------
# reranker:
#   enabled: true
#   url: "http://ollama.ollama.svc.cluster.local:11434/api/rerank"
#   model: "BAAI/bge-reranker-v2-m3"
#   candidatesMultiplier: 3

# ---------------------------------------------------------------------------
# Webhook-driven ingestion (optional, see docs/webhooks.md). When enabled,
# the rag pod exposes POST /webhook and spawns an ingestion Job on every
# verified push. The CronJob remains as a safety net.
# ---------------------------------------------------------------------------
# webhook:
#   enabled: true
#   stalenessThresholdSecs: 7200

# ---------------------------------------------------------------------------
# Discord — guildAllowlist gates the /ask command. Empty = allow every guild
# the bot is invited to. For a homelab single-server setup, lock it down to
# the one guild ID.
# ---------------------------------------------------------------------------
discordBot:
  guildAllowlist: "CHANGE_ME_guild_id"   # comma-separate to allow multiple

# ---------------------------------------------------------------------------
# Models — the `chat` value below is the bootstrap DEFAULT. After first
# deploy, prefer `/model set <name>` in Discord to change the active model
# per-instance — that writes to the instance_settings table and takes effect
# immediately (no redeploy). This value is only used when no override is
# stored in the DB. See docs/models.md.
#
# Whatever you set here MUST exist as a model alias in the LiteLLM proxy
# config. If LiteLLM returns 404 model_not_found, fix the alias there.
# ---------------------------------------------------------------------------
models:
  chat: "ollama_chat/llama3.2:3b"
  # embed/embedDim are inherited from chart defaults (text-embedding-3-small
  # at 1536). Changing these on an existing instance means re-embedding every
  # chunk — only override on a fresh DB.
  # embed: "text-embedding-3-small"
  # embedDim: 1536

# ---------------------------------------------------------------------------
# Ingestion cadence — every 6 hours by default. Tighter cadence costs more
# embedding tokens; looser cadence makes the bot lag behind merged PRs.
# Cron is interpreted in the cluster's timezone (usually UTC).
# ---------------------------------------------------------------------------
ingestion:
  schedule: "0 */6 * * *"

# ---------------------------------------------------------------------------
# Observability — Prometheus scraping. Leave disabled on clusters that do
# not run the Prometheus Operator (the CRD 'monitoring.coreos.com/v1
# ServiceMonitor' must exist). Metrics are exposed on /metrics of the rag
# Service either way. See docs/observability.md.
# ---------------------------------------------------------------------------
# observability:
#   serviceMonitor:
#     enabled: true
#     interval: 30s
#     scrapeTimeout: 10s
#     # Match whatever label your Prometheus instance's
#     # `serviceMonitorSelector` requires:
#     labels:
#       release: kube-prometheus-stack
